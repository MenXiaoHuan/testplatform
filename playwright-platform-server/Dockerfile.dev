FROM maven:3.9-eclipse-temurin-21

# Development image used by docker compose; production builds use Dockerfile.
RUN apt-get update \
    && apt-get install -y --no-install-recommends docker.io \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

EXPOSE 8080

# Run from the bind-mounted source tree so local code changes are picked up.
CMD ["mvn", "spring-boot:run"]
